# Deep Match Backend Configuration
# Copy this file to .env and fill in your values

# Security
JWT_SECRET=dev-secret-change-in-production

# Server
PORT=3000
DB_PATH=./deepmatch.db

# LLM (Local Model Support)
# For LM Studio: http://localhost:1234
# For Ollama: http://localhost:11434
LLM_HOST=http://localhost:1234
LLM_MODEL=local-model

# Optional: Email Integration (future)
# ENABLE_EMAIL_AUTH=false
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=

# Database
# For Docker: /app/data/deepmatch.db
# For local: ./deepmatch.db
